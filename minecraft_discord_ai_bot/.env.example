# Discord bot credentials
DISCORD_TOKEN=replace_me
DISCORD_CLIENT_ID=replace_me

# Use this for fast command updates while developing. Leave blank to register globally.
DISCORD_GUILD_ID=

# Optional safety gates. Leave channel list blank to allow all channels.
BOT_ALLOWED_CHANNEL_IDS=
BOT_ADMIN_ROLE_IDS=
BOT_PERSONA_STYLE=Formal, stern, statesmanlike server operator. Sound like a high-stakes security briefing, but do not impersonate a real person.
BOT_PERSONA_FILE=

# Gemini API. Create a key in Google AI Studio.
GEMINI_API_KEY=replace_me
GEMINI_MODEL=gemini-3.5-flash

# Minecraft RCON. In server.properties, set enable-rcon=true and use the same password/port.
MC_SERVER_NAME=Survival
MC_RCON_HOST=127.0.0.1
MC_RCON_PORT=25575
MC_RCON_PASSWORD=replace_me
MC_QUERY_HOST=127.0.0.1
MC_QUERY_PORT=25565

# Optional path to latest.log for better AI diagnosis.
MC_LOG_PATH=
STATUS_LOG_LINES=80

# Safety knobs
AI_AUTO_EXECUTE_SAFE_COMMANDS=true
ALLOW_STOP_COMMAND=false
BYPASS_RCON_SAFETY=false
MAX_COMMANDS_PER_FIX=6
RCON_TIMEOUT_MS=5000
