# Discord bot credentials
DISCORD_TOKEN=replace_me
DISCORD_CLIENT_ID=replace_me

# Use this for fast command updates while developing. Leave blank to register globally.
DISCORD_GUILD_ID=

# Optional safety gates. Leave channel list blank to allow all channels.
BOT_ALLOWED_CHANNEL_IDS=
BOT_ADMIN_ROLE_IDS=
BOT_PERSONA_STYLE=Formal, stern, statesmanlike server operator. Sound like a high-stakes security briefing, but do not impersonate a real person.
BOT_PERSONA_FILE=

# Gemini API. Create a key in Google AI Studio.
GEMINI_API_KEY=replace_me
GEMINI_MODEL=gemini-3.5-flash

# Minecraft RCON. In server.properties, set enable-rcon=true and use the same password/port.
MC_SERVER_NAME=Survival
MC_RCON_HOST=127.0.0.1
MC_RCON_PORT=25575
MC_RCON_PASSWORD=replace_me
MC_QUERY_HOST=127.0.0.1
MC_QUERY_PORT=25565

# Optional path to latest.log for better AI diagnosis.
MC_LOG_PATH=
STATUS_LOG_LINES=80

# Memory and image understanding
MEMORY_ENABLED=true
MEMORY_PATH=work/bibiai-memory.json
MAX_MEMORY_ITEMS=40
MAX_MEMORY_ENTRY_LENGTH=500
VISION_ENABLED=true
MAX_IMAGE_BYTES=8388608

# Short Discord timeouts for obvious rule breaks. Bot needs Moderate Members permission.
MODERATION_ENABLED=true
MODERATION_LOG_CHANNEL_ID=
MODERATION_MIN_TIMEOUT_MINUTES=1
MODERATION_MAX_TIMEOUT_MINUTES=5
MODERATION_RULE_TIMEOUT_MINUTES=5
MODERATION_OFFENSE_TIMEOUT_MINUTES=1
MODERATION_SPAM_TIMEOUT_MINUTES=2
SPAM_BIBIAI_WINDOW_MS=30000
SPAM_BIBIAI_LIMIT=4

# Persistent event log for monitor alerts, moderation actions, and reports.
EVENT_LOG_PATH=work/bibiai-events.json
EVENT_LOG_RETENTION_DAYS=60
EVENT_LOG_MAX_ITEMS=500

# Minecraft monitoring, optional recovery webhook, and weekly reports.
MC_MONITOR_ENABLED=true
MC_MONITOR_INTERVAL_MINUTES=5
MC_RECOVERY_ENABLED=false
MC_RECOVERY_WEBHOOK_URL=
MC_RECOVERY_WEBHOOK_METHOD=POST
MC_RECOVERY_OFFLINE_CHECKS=2
PEBBLEHOST_API_ENABLED=false
PEBBLEHOST_API_TOKEN=
PEBBLEHOST_SERVER_ID=
PEBBLEHOST_RECOVERY_SIGNAL=start
PEBBLEHOST_API_BASE_URL=https://panel.pebblehost.com

# New player join help
JOIN_SERVER_ADDRESS=
JOIN_MODPACK_NAME=Server modpack
JOIN_MODPACK_URL=
JOIN_MODPACK_LOADER=CurseForge
JOIN_MINECRAFT_VERSION=
JOIN_INSTALL_GUIDE_URL=
JOIN_HELP_CHANNEL_ID=
JOIN_EXTRA_NOTES=
JOIN_AUTO_REPLY_ENABLED=true

MINECRAFT_REPORT_CHANNEL_ID=
WEEKLY_REPORT_ENABLED=true
WEEKLY_REPORT_DAY=sunday
WEEKLY_REPORT_HOUR_UTC=18

# Safety knobs
AI_AUTO_EXECUTE_SAFE_COMMANDS=true
ALLOW_STOP_COMMAND=false
BYPASS_RCON_SAFETY=false
MAX_COMMANDS_PER_FIX=6
RCON_TIMEOUT_MS=5000
